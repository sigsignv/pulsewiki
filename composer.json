{
    "name": "sigsign/pulsewiki",
    "description": "A wiki framework written in PHP",
    "license": "GPL-2.0-or-later",
    "autoload": {
        "psr-4": {
            "Pulsewiki\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pulsewiki\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit -c tests/phpunit.dist.xml"
    },
    "config": {
        "platform": {
            "php": "8.1.0"
        },
        "sort-packages": true
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpunit/phpunit": "^10.5"
    }
}
